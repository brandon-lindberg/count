APP_NAME=Steam Player Count Scraper
ENVIRONMENT=development
DEBUG=true
DATABASE_URL=postgresql+asyncpg://localhost:5432/player_count_scraper
DATABASE_ECHO=false
MIRROR_DATABASE_URL=
MIRROR_DATABASE_USE_SSL=false
REQUIRE_MIRROR_SUCCESS=false

SOURCE_API_BASE_URL=http://localhost:8000
SOURCE_API_TOKEN=
SOURCE_API_PAGE_SIZE=100
SOURCE_API_MAX_PAGES=

SERVICE_API_TOKEN=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
DISABLE_AUTH=true

HOT_POLL_MINUTES=60
WARM_POLL_MINUTES=180
COLD_POLL_MINUTES=180
BOOTSTRAP_POLL_MINUTES=5
REGISTRY_IMPORT_MINUTES=15
RELEASE_HOT_DAYS=3
WARM_FLOOR_MONTHS=15
HOT_THRESHOLD=10000
WARM_THRESHOLD=500
ENABLE_COLD_POLLING=false
POLL_BATCH_LIMIT=250
HOT_POLL_BATCH_LIMIT=250
WARM_POLL_BATCH_LIMIT=2500
BOOTSTRAP_BATCH_LIMIT=500
WORKER_CYCLE_MAX_SECONDS=
WORKER_CYCLE_SHUTDOWN_GRACE_SECONDS=60
STARTUP_BOOTSTRAP_MAX_BATCHES=25
NOT_FOUND_RETRY_HOURS=24
LAUNCH_NOT_FOUND_RETRY_MINUTES=15
LAUNCH_PRIORITY_PAST_DAYS=3
LAUNCH_PRIORITY_FUTURE_DAYS=2
HTTP_TIMEOUT_SECONDS=20
PARTITION_MONTHS_AHEAD=2
